{
  "name": "ecommerce",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "pnpm --filter @ecommerce/api dev",
    "dev:web": "pnpm --filter @ecommerce/web dev",
    "build": "pnpm build:shared && pnpm build:db && pnpm build:api && pnpm build:web",
    "build:shared": "pnpm --filter @ecommerce/shared build",
    "build:db": "pnpm --filter @ecommerce/db build",
    "build:api": "pnpm --filter @ecommerce/api build",
    "build:web": "pnpm --filter @ecommerce/web build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @ecommerce/api test",
    "test:web": "pnpm --filter @ecommerce/web test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @ecommerce/db db:generate",
    "db:migrate": "pnpm --filter @ecommerce/db db:migrate",
    "db:push": "pnpm --filter @ecommerce/db db:push",
    "db:seed": "pnpm --filter @ecommerce/db db:seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
