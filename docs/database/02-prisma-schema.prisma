// ============================================================================
// E-COMMERCE PLATFORM - COMPLETE PRISMA SCHEMA
// Version: 1.0.0
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

// User & Auth Enums
enum UserStatus {
  active
  suspended
  deactivated
  pending_verification
}

enum AuthProvider {
  local
  google
  github
  facebook
  apple
}

enum MfaMethod {
  totp
  sms
  email
}

enum Gender {
  male
  female
  other
  prefer_not_to_say
}

enum AddressType {
  home
  work
  other
}

enum SessionStatus {
  active
  expired
  revoked
}

// Product & Catalog Enums
enum ProductStatus {
  draft
  active
  archived
  discontinued
}

enum ProductType {
  physical
  digital
  service
  subscription
}

enum AttributeType {
  text
  number
  select
  multi_select
  boolean
  date
}

enum VariantStatus {
  active
  inactive
  out_of_stock
}

// Order & Commerce Enums
enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  returned
  refunded
  on_hold
  failed
}

enum PaymentStatus {
  pending
  processing
  completed
  failed
  cancelled
  refunded
  partially_refunded
  disputed
}

enum PaymentMethodType {
  credit_card
  debit_card
  paypal
  stripe
  bank_transfer
  cash_on_delivery
  digital_wallet
}

enum ShipmentStatus {
  pending
  label_created
  dispatched
  in_transit
  out_for_delivery
  delivered
  exception
  returned
}

enum RefundStatus {
  pending
  processing
  completed
  failed
  rejected
}

enum ReturnStatus {
  pending
  approved
  rejected
  received
  completed
}

// Content Enums
enum ContentStatus {
  draft
  published
  archived
  scheduled
}

enum BannerPosition {
  home_hero
  home_sidebar
  category_top
  checkout_top
  footer
}

enum NotificationChannel {
  email
  sms
  push
  in_app
}

enum NotificationStatus {
  pending
  sent
  delivered
  read
  failed
}

enum ReviewStatus {
  pending
  approved
  rejected
  flagged
}

enum ReportReason {
  spam
  inappropriate
  fake
  offensive
  other
}

// System Enums
enum AuditAction {
  create
  update
  delete
  login
  logout
  export
  import
  approve
  reject
}

enum LogLevel {
  debug
  info
  warning
  error
  critical
}

enum SettingType {
  string
  number
  boolean
  json
  text
}

enum MediaType {
  image
  video
  document
  audio
  other
}

enum SortOrder {
  asc
  desc
}

enum ThemeMode {
  light
  dark
  system
}

// ============================================================================
// MODELS
// ============================================================================

// ============================================================================
// 1. AUTH MODULE
// ============================================================================

model User {
  id                    String         @id @default(uuid()) @db.Uuid
  email                 String         @unique @db.VarChar(255)
  emailVerified         Boolean        @default(false) @map("email_verified")
  emailVerifiedAt       DateTime?      @map("email_verified_at")
  phone                 String?        @db.VarChar(20)
  phoneVerified         Boolean        @default(false) @map("phone_verified")
  phoneVerifiedAt       DateTime?      @map("phone_verified_at")
  passwordHash          String?        @map("password_hash") @db.VarChar(255)
  status                UserStatus     @default(pending_verification)
  mfaEnabled            Boolean        @default(false) @map("mfa_enabled")
  mfaSecret             String?        @map("mfa_secret") @db.VarChar(255)
  mfaMethod             MfaMethod?     @map("mfa_method")
  failedLoginAttempts   Int            @default(0) @map("failed_login_attempts")
  lockedUntil           DateTime?      @map("locked_until")
  lastLoginAt           DateTime?      @map("last_login_at")
  lastLoginIp           String?        @map("last_login_ip") @db.Inet
  passwordChangedAt     DateTime?      @map("password_changed_at")
  metadata              Json?          @default("{}")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  deletedAt             DateTime?      @map("deleted_at")

  // Relations
  profile               UserProfile?
  oauthConnections      OAuthConnection[]
  roles                 UserRole[]
  sessions              Session[]
  refreshTokens         RefreshToken[]
  passwordResetTokens   PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  addresses             Address[]
  preferences           UserPreference?
  reviews               Review[]
  comments              Comment[]
  wishlists             Wishlist[]
  notifications         Notification[]
  notificationPreferences NotificationPreference[]
  orders                Order[]
  payments              Payment[]
  paymentMethods        PaymentMethod[]
  couponUsages          CouponUsage[]
  deviceHistory         DeviceHistory[]
  activityLogs          ActivityLog[]
  analyticsEvents       AnalyticsEvent[]

  @@index([status])
  @@index([createdAt])
  @@map("users")
}

model OAuthConnection {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  provider          AuthProvider
  providerUserId    String       @map("provider_user_id") @db.VarChar(255)
  providerEmail     String?      @map("provider_email") @db.VarChar(255)
  accessToken       String?      @db.Text
  refreshToken      String?      @db.Text
  tokenExpiresAt    DateTime?    @map("token_expires_at")
  providerData      Json?        @default("{}") @map("provider_data")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  // Relations
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_connections")
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @db.VarChar(50)
  description String?
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  roles       RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  userId      String   @map("user_id") @db.Uuid
  roleId      String   @map("role_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")

  // Relations
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  tokenHash         String        @map("token_hash") @db.VarChar(255)
  refreshTokenHash  String?       @map("refresh_token_hash") @db.VarChar(255)
  ipAddress         String?       @map("ip_address") @db.Inet
  userAgent         String?       @map("user_agent")
  deviceInfo        Json?         @default("{}") @map("device_info")
  status            SessionStatus @default(active)
  lastActivityAt    DateTime      @default(now()) @map("last_activity_at")
  expiresAt         DateTime      @map("expires_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  // Relations
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id              String     @id @default(uuid()) @db.Uuid
  userId          String     @map("user_id") @db.Uuid
  tokenHash       String     @map("token_hash") @db.VarChar(255)
  familyId        String     @map("family_id") @db.Uuid
  ipAddress       String?    @map("ip_address") @db.Inet
  userAgent       String?    @map("user_agent")
  expiresAt       DateTime   @map("expires_at")
  revokedAt       DateTime?  @map("revoked_at")
  createdAt       DateTime   @default(now()) @map("created_at")

  // Relations
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  tokenHash   String     @map("token_hash") @db.VarChar(255)
  expiresAt   DateTime   @map("expires_at")
  usedAt      DateTime?  @map("used_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  // Relations
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  tokenHash   String     @map("token_hash") @db.VarChar(255)
  email       String     @db.VarChar(255)
  expiresAt   DateTime   @map("expires_at")
  verifiedAt  DateTime?  @map("verified_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  // Relations
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

// ============================================================================
// 2. USER PROFILE MODULE
// ============================================================================

model UserProfile {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @map("user_id") @db.Uuid
  firstName     String?   @map("first_name") @db.VarChar(100)
  lastName      String?   @map("last_name") @db.VarChar(100)
  displayName   String?   @map("display_name") @db.VarChar(150)
  avatarUrl     String?   @map("avatar_url") @db.Text
  coverUrl      String?   @map("cover_url") @db.Text
  dateOfBirth   DateTime? @map("date_of_birth") @db.Date
  gender        Gender?
  bio           String?   @db.Text
  company       String?   @db.VarChar(200)
  website       String?   @db.VarChar(500)
  locale        String?   @default("en") @db.VarChar(10)
  timezone      String?   @default("UTC") @db.VarChar(50)
  metadata      Json?     @default("{}")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Address {
  id                String      @id @default(uuid()) @db.Uuid
  userId            String      @map("user_id") @db.Uuid
  type              AddressType @default(home)
  label             String?     @db.VarChar(50)
  firstName         String      @map("first_name") @db.VarChar(100)
  lastName          String      @map("last_name") @db.VarChar(100)
  company           String?     @db.VarChar(200)
  addressLine1      String      @map("address_line_1") @db.VarChar(255)
  addressLine2      String?     @map("address_line_2") @db.VarChar(255)
  city              String      @db.VarChar(100)
  state             String?     @db.VarChar(100)
  postalCode        String      @map("postal_code") @db.VarChar(20)
  countryCode       String      @map("country_code") @db.Char(2)
  phone             String?     @db.VarChar(20)
  isDefault         Boolean     @default(false) @map("is_default")
  latitude          Decimal?    @db.Decimal(10, 8)
  longitude         Decimal?    @db.Decimal(11, 8)
  deliveryInstructions String?  @map("delivery_instructions") @db.Text
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  deletedAt         DateTime?   @map("deleted_at")

  // Relations
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model UserPreference {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @unique @map("user_id") @db.Uuid
  emailNotifications  Boolean  @default(true) @map("email_notifications")
  smsNotifications    Boolean  @default(false) @map("sms_notifications")
  pushNotifications   Boolean  @default(true) @map("push_notifications")
  marketingEmails     Boolean  @default(true) @map("marketing_emails")
  orderUpdates        Boolean  @default(true) @map("order_updates")
  newsletterSubscribed Boolean @default(false) @map("newsletter_subscribed")
  currency            String?  @default("USD") @db.VarChar(3)
  language            String?  @default("en") @db.VarChar(10)
  theme               ThemeMode @default(system)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ============================================================================
// 3. CATALOG MODULE
// ============================================================================

model Category {
  id              String     @id @default(uuid()) @db.Uuid
  parentId        String?    @map("parent_id") @db.Uuid
  name            String     @db.VarChar(200)
  slug            String     @unique @db.VarChar(220)
  description     String?    @db.Text
  imageUrl        String?    @map("image_url") @db.Text
  icon            String?    @db.VarChar(50)
  bannerUrl       String?    @map("banner_url") @db.Text
  metaTitle       String?    @map("meta_title") @db.VarChar(200)
  metaDescription String?    @map("meta_description") @db.VarChar(500)
  sortOrder       Int        @default(0) @map("sort_order")
  isActive        Boolean    @default(true) @map("is_active")
  isFeatured      Boolean    @default(false) @map("is_featured")
  level           Int        @default(0)
  path            String     @db.VarChar(500)
  productCount    Int        @default(0) @map("product_count")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  // Relations
  parent          Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children        Category[] @relation("CategoryTree")
  products        Product[]
  productCategories ProductCategory[]

  @@index([parentId])
  @@index([sortOrder])
  @@map("categories")
}

model Brand {
  id              String     @id @default(uuid()) @db.Uuid
  name            String     @db.VarChar(200)
  slug            String     @unique @db.VarChar(220)
  description     String?    @db.Text
  logoUrl         String?    @map("logo_url") @db.Text
  bannerUrl       String?    @map("banner_url") @db.Text
  websiteUrl      String?    @map("website_url") @db.VarChar(500)
  isActive        Boolean    @default(true) @map("is_active")
  isFeatured      Boolean    @default(false) @map("is_featured")
  sortOrder       Int        @default(0) @map("sort_order")
  metaTitle       String?    @map("meta_title") @db.VarChar(200)
  metaDescription String?    @map("meta_description") @db.VarChar(500)
  productCount    Int        @default(0) @map("product_count")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  // Relations
  products        Product[]

  @@map("brands")
}

model Attribute {
  id            String        @id @default(uuid()) @db.Uuid
  name          String        @db.VarChar(100)
  slug          String        @unique @db.VarChar(120)
  type          AttributeType @default(text)
  options       Json?
  isFilterable  Boolean       @default(false) @map("is_filterable")
  isVariant     Boolean       @default(false) @map("is_variant")
  isRequired    Boolean       @default(false) @map("is_required")
  sortOrder     Int           @default(0) @map("sort_order")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  productAttributeValues ProductAttributeValue[]

  @@map("attributes")
}

model Product {
  id                String        @id @default(uuid()) @db.Uuid
  sku               String        @unique @db.VarChar(100)
  name              String        @db.VarChar(500)
  slug              String        @unique @db.VarChar(520)
  description       String?       @db.Text
  shortDescription  String?       @map("short_description") @db.VarChar(500)
  productType       ProductType   @default(physical) @map("product_type")
  categoryId        String        @map("category_id") @db.Uuid
  brandId           String?       @map("brand_id") @db.Uuid
  status            ProductStatus @default(draft)
  isFeatured        Boolean       @default(false) @map("is_featured")
  isDigital         Boolean       @default(false) @map("is_digital")
  isTaxable         Boolean       @default(true) @map("is_taxable")
  weight            Decimal?      @db.Decimal(10, 3)
  weightUnit        String?       @default("kg") @map("weight_unit") @db.VarChar(5)
  length            Decimal?      @db.Decimal(10, 2)
  width             Decimal?      @db.Decimal(10, 2)
  height            Decimal?      @db.Decimal(10, 2)
  dimensionUnit     String?       @default("cm") @map("dimension_unit") @db.VarChar(5)
  metaTitle         String?       @map("meta_title") @db.VarChar(200)
  metaDescription   String?       @map("meta_description") @db.VarChar(500)
  tags              String[]
  attributes        Json?         @default("{}")
  pricing           Json?         @default("{}")
  stockQuantity     Int           @default(0) @map("stock_quantity")
  lowStockThreshold Int           @default(10) @map("low_stock_threshold")
  ratingAverage     Decimal?      @default(0) @map("rating_average") @db.Decimal(3, 2)
  ratingCount       Int           @default(0) @map("rating_count")
  reviewCount       Int           @default(0) @map("review_count")
  viewCount         Int           @default(0) @map("view_count")
  soldCount         Int           @default(0) @map("sold_count")
  sortOrder         Int           @default(0) @map("sort_order")
  publishedAt       DateTime?     @map("published_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  deletedAt         DateTime?     @map("deleted_at")

  // Relations
  category          Category      @relation(fields: [categoryId], references: [id])
  brand             Brand?        @relation(fields: [brandId], references: [id])
  variants          ProductVariant[]
  productCategories ProductCategory[]
  productImages     ProductImage[]
  productVideos     ProductVideo[]
  productAttributeValues ProductAttributeValue[]
  reviews           Review[]
  orderItems        OrderItem[]
  cartItems         CartItem[]
  wishlistItems     WishlistItem[]
  prices            Price[]

  @@index([categoryId])
  @@index([brandId])
  @@index([status])
  @@index([isFeatured])
  @@index([ratingAverage])
  @@index([createdAt])
  @@map("products")
}

model ProductCategory {
  productId  String   @map("product_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  isPrimary  Boolean  @default(false) @map("is_primary")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

model ProductVariant {
  id                String        @id @default(uuid()) @db.Uuid
  productId         String        @map("product_id") @db.Uuid
  sku               String        @unique @db.VarChar(100)
  name              String        @db.VarChar(200)
  attributes        Json          @default("{}")
  price             Decimal       @db.Decimal(12, 2)
  compareAtPrice    Decimal?      @map("compare_at_price") @db.Decimal(12, 2)
  costPrice         Decimal?      @map("cost_price") @db.Decimal(12, 2)
  barcode           String?       @db.VarChar(100)
  imageUrl          String?       @map("image_url") @db.Text
  weight            Decimal?      @db.Decimal(10, 3)
  stockQuantity     Int           @default(0) @map("stock_quantity")
  lowStockThreshold Int           @default(5) @map("low_stock_threshold")
  status            VariantStatus @default(active)
  sortOrder         Int           @default(0) @map("sort_order")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  deletedAt         DateTime?     @map("deleted_at")

  // Relations
  product           Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  productImages     ProductImage[]
  orderItems        OrderItem[]
  cartItems         CartItem[]
  wishlistItems     WishlistItem[]

  @@index([productId])
  @@index([status])
  @@map("product_variants")
}

model ProductAttributeValue {
  id          String     @id @default(uuid()) @db.Uuid
  productId   String     @map("product_id") @db.Uuid
  attributeId String     @map("attribute_id") @db.Uuid
  value       String     @db.Text
  createdAt   DateTime   @default(now()) @map("created_at")

  // Relations
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute   Attribute  @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([attributeId])
  @@map("product_attribute_values")
}

model ProductImage {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  variantId   String?  @map("variant_id") @db.Uuid
  mediaId     String   @map("media_id") @db.Uuid
  altText     String?  @map("alt_text") @db.VarChar(255)
  title       String?  @db.VarChar(255)
  sortOrder   Int      @default(0) @map("sort_order")
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  product     Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@map("product_images")
}

model ProductVideo {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  mediaId     String   @map("media_id") @db.Uuid
  title       String?  @db.VarChar(255)
  description String?  @db.Text
  duration    Decimal? @db.Decimal(10, 2)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_videos")
}

// ============================================================================
// 4. INVENTORY MODULE
// ============================================================================

model Warehouse {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(200)
  code            String   @unique @db.VarChar(50)
  description     String?  @db.Text
  addressLine1    String?  @map("address_line_1") @db.VarChar(255)
  addressLine2    String?  @map("address_line_2") @db.VarChar(255)
  city            String?  @db.VarChar(100)
  state           String?  @db.VarChar(100)
  postalCode      String?  @map("postal_code") @db.VarChar(20)
  countryCode     String?  @map("country_code") @db.Char(2)
  phone           String?  @db.VarChar(20)
  email           String?  @db.VarChar(255)
  isActive        Boolean  @default(true) @map("is_active")
  isDefault       Boolean  @default(false) @map("is_default")
  priority        Int      @default(0)
  metadata        Json?    @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  inventory       Inventory[]
  stockMovements  StockMovement[]
  stockReservations StockReservation[]
  shipments       Shipment[]

  @@map("warehouses")
}

model Inventory {
  id                  String   @id @default(uuid()) @db.Uuid
  productId           String   @map("product_id") @db.Uuid
  variantId           String?  @map("variant_id") @db.Uuid
  warehouseId         String   @map("warehouse_id") @db.Uuid
  quantity            Int      @default(0)
  reservedQuantity    Int      @default(0) @map("reserved_quantity")
  availableQuantity   Int      @default(0) @map("available_quantity") @db.GeneratedAlwaysAs("quantity - reserved_quantity")
  lowStockThreshold   Int      @default(10) @map("low_stock_threshold")
  reorderPoint        Int?     @map("reorder_point")
  reorderQuantity     Int?     @map("reorder_quantity")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  warehouse           Warehouse     @relation(fields: [warehouseId], references: [id])
  stockMovements      StockMovement[]

  @@unique([productId, variantId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@map("inventory")
}

model StockMovement {
  id            String   @id @default(uuid()) @db.Uuid
  inventoryId   String   @map("inventory_id") @db.Uuid
  type          String   @db.VarChar(30)
  quantity      Int
  referenceType String?  @map("reference_type") @db.VarChar(50)
  referenceId   String?  @map("reference_id") @db.Uuid
  reason        String?  @db.Text
  performedBy   String?  @map("performed_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  inventory     Inventory @relation(fields: [inventoryId], references: [id])

  @@index([inventoryId])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  @@map("stock_movements")
}

model StockReservation {
  id            String   @id @default(uuid()) @db.Uuid
  orderId       String   @map("order_id") @db.Uuid
  productId     String   @map("product_id") @db.Uuid
  variantId     String?  @map("variant_id") @db.Uuid
  warehouseId   String   @map("warehouse_id") @db.Uuid
  quantity      Int
  status        String   @default("active") @db.VarChar(20)
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([status])
  @@index([expiresAt])
  @@map("stock_reservations")
}

// ============================================================================
// 5. PRICING MODULE
// ============================================================================

model Currency {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(3)
  name          String   @db.VarChar(100)
  symbol        String   @db.VarChar(10)
  decimalPlaces Int      @default(2) @map("decimal_places")
  isActive      Boolean  @default(true) @map("is_active")
  isDefault     Boolean  @default(false) @map("is_default")
  exchangeRate  Decimal? @default(1) @map("exchange_rate") @db.Decimal(20, 10)
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  exchangeRatesFrom ExchangeRate[] @relation("FromCurrency")
  exchangeRatesTo   ExchangeRate[] @relation("ToCurrency")
  prices            Price[]
  orders            Order[]
  payments          Payment[]
  refunds           Refund[]

  @@map("currencies")
}

model ExchangeRate {
  id             String   @id @default(uuid()) @db.Uuid
  fromCurrency   String   @map("from_currency") @db.VarChar(3)
  toCurrency     String   @map("to_currency") @db.VarChar(3)
  rate           Decimal  @db.Decimal(20, 10)
  source         String   @db.VarChar(50)
  effectiveAt    DateTime @default(now()) @map("effective_at")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  fromCurrencyRel Currency @relation("FromCurrency", fields: [fromCurrency], references: [code])
  toCurrencyRel   Currency @relation("ToCurrency", fields: [toCurrency], references: [code])

  @@index([fromCurrency, toCurrency])
  @@index([effectiveAt])
  @@map("exchange_rates")
}

model Price {
  id              String    @id @default(uuid()) @db.Uuid
  productId       String    @map("product_id") @db.Uuid
  variantId       String?   @map("variant_id") @db.Uuid
  currency        String    @db.VarChar(3)
  price           Decimal   @db.Decimal(12, 2)
  compareAtPrice  Decimal?  @map("compare_at_price") @db.Decimal(12, 2)
  costPrice       Decimal?  @map("cost_price") @db.Decimal(12, 2)
  minQuantity     Int       @default(1) @map("min_quantity")
  startsAt        DateTime? @map("starts_at")
  endsAt          DateTime? @map("ends_at")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  product         Product   @relation(fields: [productId], references: [id])
  currencyRel     Currency  @relation(fields: [currency], references: [code])

  @@index([productId])
  @@index([currency])
  @@index([isActive, startsAt, endsAt])
  @@map("prices")
}

model Discount {
  id              String     @id @default(uuid()) @db.Uuid
  name            String     @db.VarChar(200)
  description     String?    @db.Text
  type            String     @db.VarChar(20)
  value           Decimal    @db.Decimal(12, 2)
  maxUses         Int?       @map("max_uses")
  usedCount       Int        @default(0) @map("used_count")
  minOrderAmount  Decimal?   @map("min_order_amount") @db.Decimal(12, 2)
  minQuantity     Int?       @map("min_quantity")
  productIds      String[]   @map("product_ids")
  categoryIds     String[]   @map("category_ids")
  startsAt        DateTime?  @map("starts_at")
  endsAt          DateTime?  @map("ends_at")
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@map("discounts")
}

// ============================================================================
// 6. CART MODULE
// ============================================================================

model Cart {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String?   @map("user_id") @db.Uuid
  sessionId       String?   @map("session_id") @db.VarChar(255)
  status          String    @default("active") @db.VarChar(20)
  currency        String    @default("USD") @db.VarChar(3)
  subtotal        Decimal   @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount       Decimal   @default(0) @map("tax_amount") @db.Decimal(12, 2)
  shippingAmount  Decimal   @default(0) @map("shipping_amount") @db.Decimal(12, 2)
  total           Decimal   @default(0) @db.Decimal(12, 2)
  couponCode      String?   @map("coupon_code") @db.VarChar(50)
  notes           String?   @db.Text
  metadata        Json?     @default("{}")
  expiresAt       DateTime? @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  abandonedAt     DateTime? @map("abandoned_at")

  // Relations
  items           CartItem[]

  @@index([userId])
  @@index([sessionId])
  @@index([status])
  @@index([abandonedAt])
  @@map("carts")
}

model CartItem {
  id              String   @id @default(uuid()) @db.Uuid
  cartId          String   @map("cart_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  variantId       String?  @map("variant_id") @db.Uuid
  quantity        Int      @default(1)
  price           Decimal  @db.Decimal(12, 2)
  compareAtPrice  Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  discountAmount  Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount       Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  options         Json?    @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  cart            Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id])
  variant         ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// ============================================================================
// 7. ORDER MODULE
// ============================================================================

model Order {
  id                String        @id @default(uuid()) @db.Uuid
  orderNumber       String        @unique @map("order_number") @db.VarChar(50)
  userId            String        @map("user_id") @db.Uuid
  status            OrderStatus   @default(pending)
  currency          String        @default("USD") @db.VarChar(3)
  subtotal          Decimal       @db.Decimal(12, 2)
  discountAmount    Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount         Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  shippingAmount    Decimal       @default(0) @map("shipping_amount") @db.Decimal(12, 2)
  total             Decimal       @db.Decimal(12, 2)
  notes             String?       @db.Text
  internalNotes     String?       @map("internal_notes") @db.Text
  ipAddress         String?       @map("ip_address") @db.Inet
  userAgent         String?       @map("user_agent")
  metadata          Json?         @default("{}")
  placedAt          DateTime?     @map("placed_at")
  confirmedAt       DateTime?     @map("confirmed_at")
  shippedAt         DateTime?     @map("shipped_at")
  deliveredAt       DateTime?     @map("delivered_at")
  cancelledAt       DateTime?     @map("cancelled_at")
  cancelReason      String?       @map("cancel_reason") @db.Text
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  deletedAt         DateTime?     @map("deleted_at")

  // Relations
  currencyRel       Currency      @relation(fields: [currency], references: [code])
  items             OrderItem[]
  statusHistory     OrderStatusHistory[]
  addresses         OrderAddress[]
  payments          Payment[]
  refunds           Refund[]
  shipments         Shipment[]
  couponUsages      CouponUsage[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  variantId       String?  @map("variant_id") @db.Uuid
  sku             String   @db.VarChar(100)
  name            String   @db.VarChar(500)
  imageUrl        String?  @map("image_url") @db.Text
  quantity        Int
  unitPrice       Decimal  @map("unit_price") @db.Decimal(12, 2)
  discountAmount  Decimal  @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount       Decimal  @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  options         Json?    @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  order           Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product        @relation(fields: [productId], references: [id])
  variant         ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id          String      @id @default(uuid()) @db.Uuid
  orderId     String      @map("order_id") @db.Uuid
  status      OrderStatus
  note        String?     @db.Text
  performedBy String?     @map("performed_by") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
  @@map("order_status_history")
}

model OrderAddress {
  id              String   @id @default(uuid()) @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  type            String   @db.VarChar(20)
  firstName       String   @map("first_name") @db.VarChar(100)
  lastName        String   @map("last_name") @db.VarChar(100)
  company         String?  @db.VarChar(200)
  addressLine1    String   @map("address_line_1") @db.VarChar(255)
  addressLine2    String?  @map("address_line_2") @db.VarChar(255)
  city            String   @db.VarChar(100)
  state           String?  @db.VarChar(100)
  postalCode      String   @map("postal_code") @db.VarChar(20)
  countryCode     String   @map("country_code") @db.Char(2)
  phone           String?  @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_addresses")
}

// ============================================================================
// 8. PAYMENT MODULE
// ============================================================================

model Payment {
  id                    String            @id @default(uuid()) @db.Uuid
  orderId               String            @map("order_id") @db.Uuid
  userId                String            @map("user_id") @db.Uuid
  status                PaymentStatus     @default(pending)
  amount                Decimal           @db.Decimal(12, 2)
  currency              String            @db.VarChar(3)
  method                PaymentMethodType
  provider              String            @db.VarChar(50)
  providerTransactionId String?           @map("provider_transaction_id") @db.VarChar(255)
  providerMetadata      Json?             @default("{}") @map("provider_metadata")
  failureReason         String?           @map("failure_reason") @db.Text
  failureCode           String?           @map("failure_code") @db.VarChar(50)
  idempotencyKey        String?           @unique @map("idempotency_key") @db.VarChar(255)
  metadata              Json?             @default("{}")
  paidAt                DateTime?         @map("paid_at")
  failedAt              DateTime?         @map("failed_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  // Relations
  order                 Order             @relation(fields: [orderId], references: [id])
  currencyRel           Currency          @relation(fields: [currency], references: [code])
  refunds               Refund[]
  transactions          PaymentTransaction[]

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([providerTransactionId])
  @@map("payments")
}

model Refund {
  id                String        @id @default(uuid()) @db.Uuid
  paymentId         String        @map("payment_id") @db.Uuid
  orderId           String        @map("order_id") @db.Uuid
  amount            Decimal       @db.Decimal(12, 2)
  reason            String?       @db.Text
  status            RefundStatus  @default(pending)
  providerRefundId  String?       @map("provider_refund_id") @db.VarChar(255)
  metadata          Json?         @default("{}")
  processedAt       DateTime?     @map("processed_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  payment           Payment       @relation(fields: [paymentId], references: [id])
  order             Order         @relation(fields: [orderId], references: [id])
  currencyRel       Currency      @relation(fields: [currency], references: [code])

  @@index([paymentId])
  @@index([orderId])
  @@index([status])
  @@map("refunds")
}

model PaymentMethod {
  id                        String            @id @default(uuid()) @db.Uuid
  userId                    String            @map("user_id") @db.Uuid
  type                      PaymentMethodType
  provider                  String            @db.VarChar(50)
  providerPaymentMethodId   String            @map("provider_payment_method_id") @db.VarChar(255)
  lastFour                  String?           @map("last_four") @db.VarChar(4)
  brand                     String?           @db.VarChar(50)
  expMonth                  Int?              @map("exp_month")
  expYear                   Int?              @map("exp_year")
  isDefault                 Boolean           @default(false) @map("is_default")
  billingAddress            Json?             @map("billing_address")
  metadata                  Json?             @default("{}")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @updatedAt @map("updated_at")
  deletedAt                 DateTime?         @map("deleted_at")

  // Relations
  user                      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payment_methods")
}

model PaymentTransaction {
  id                    String   @id @default(uuid()) @db.Uuid
  paymentId             String   @map("payment_id") @db.Uuid
  type                  String   @db.VarChar(20)
  amount                Decimal  @db.Decimal(12, 2)
  currency              String   @db.VarChar(3)
  status                String   @db.VarChar(20)
  provider              String   @db.VarChar(50)
  providerTransactionId String?  @map("provider_transaction_id") @db.VarChar(255)
  metadata              Json?    @default("{}")
  createdAt             DateTime @default(now()) @map("created_at")

  // Relations
  payment               Payment  @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@map("payment_transactions")
}

// ============================================================================
// 9. SHIPPING MODULE
// ============================================================================

model Carrier {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String   @db.VarChar(200)
  code                  String   @unique @db.VarChar(50)
  apiUrl                String?  @map("api_url") @db.Text
  apiKeyEncrypted       String?  @map("api_key_encrypted") @db.Text
  trackingUrlTemplate   String?  @map("tracking_url_template") @db.Text
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  methods               ShippingMethod[]
  shipments             Shipment[]

  @@map("carriers")
}

model ShippingMethod {
  id                    String   @id @default(uuid()) @db.Uuid
  carrierId             String   @map("carrier_id") @db.Uuid
  name                  String   @db.VarChar(200)
  code                  String   @db.VarChar(50)
  description           String?  @db.Text
  estimatedDaysMin      Int?     @map("estimated_days_min")
  estimatedDaysMax      Int?     @map("estimated_days_max")
  baseRate              Decimal  @map("base_rate") @db.Decimal(12, 2)
  perKgRate             Decimal? @map("per_kg_rate") @db.Decimal(12, 2)
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  carrier               Carrier  @relation(fields: [carrierId], references: [id])
  shipments             Shipment[]
  shippingRates         ShippingRate[]

  @@index([carrierId])
  @@map("shipping_methods")
}

model Shipment {
  id                    String          @id @default(uuid()) @db.Uuid
  orderId               String          @map("order_id") @db.Uuid
  shippingMethodId      String          @map("shipping_method_id") @db.Uuid
  status                ShipmentStatus  @default(pending)
  trackingNumber        String?         @map("tracking_number") @db.VarChar(255)
  carrierId             String          @map("carrier_id") @db.Uuid
  weight                Decimal?        @db.Decimal(10, 3)
  weightUnit            String?         @default("kg") @map("weight_unit") @db.VarChar(5)
  shippingCost          Decimal?        @map("shipping_cost") @db.Decimal(12, 2)
  fromAddress           Json            @map("from_address")
  toAddress             Json            @map("to_address")
  estimatedDelivery     DateTime?       @map("estimated_delivery")
  actualDelivery        DateTime?       @map("actual_delivery")
  signatureRequired     Boolean         @default(false) @map("signature_required")
  signedBy              String?         @map("signed_by") @db.VarChar(200)
  metadata              Json?           @default("{}")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  // Relations
  order                 Order           @relation(fields: [orderId], references: [id])
  shippingMethod        ShippingMethod  @relation(fields: [shippingMethodId], references: [id])
  carrier               Carrier         @relation(fields: [carrierId], references: [id])

  @@index([orderId])
  @@index([trackingNumber])
  @@index([status])
  @@map("shipments")
}

model ShippingRate {
  id                    String   @id @default(uuid()) @db.Uuid
  shippingMethodId      String   @map("shipping_method_id") @db.Uuid
  countryCode           String?  @map("country_code") @db.Char(2)
  state                 String?  @db.VarChar(100)
  postalCodeFrom        String?  @map("postal_code_from") @db.VarChar(20)
  postalCodeTo          String?  @map("postal_code_to") @db.VarChar(20)
  minWeight             Decimal? @map("min_weight") @db.Decimal(10, 3)
  maxWeight             Decimal? @map("max_weight") @db.Decimal(10, 3)
  rate                  Decimal  @db.Decimal(12, 2)
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  // Relations
  shippingMethod        ShippingMethod @relation(fields: [shippingMethodId], references: [id])

  @@index([shippingMethodId])
  @@map("shipping_rates")
}

// ============================================================================
// 10. COUPON & PROMOTION MODULE
// ============================================================================

model Coupon {
  id                String        @id @default(uuid()) @db.Uuid
  code              String        @unique @db.VarChar(50)
  description       String?       @db.Text
  type              String        @db.VarChar(20)
  value             Decimal       @db.Decimal(12, 2)
  minOrderAmount    Decimal?      @map("min_order_amount") @db.Decimal(12, 2)
  minQuantity       Int?          @map("min_quantity")
  maxUses           Int?          @map("max_uses")
  maxUsesPerUser    Int?          @default(1) @map("max_uses_per_user")
  usedCount         Int           @default(0) @map("used_count")
  productIds        String[]      @map("product_ids")
  categoryIds       String[]      @map("category_ids")
  excludeProductIds String[]      @map("exclude_product_ids")
  startsAt          DateTime?     @map("starts_at")
  endsAt            DateTime?     @map("ends_at")
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // Relations
  usages            CouponUsage[]

  @@index([isActive, startsAt, endsAt])
  @@map("coupons")
}

model CouponUsage {
  id              String   @id @default(uuid()) @db.Uuid
  couponId        String   @map("coupon_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  orderId         String   @map("order_id") @db.Uuid
  discountAmount  Decimal  @map("discount_amount") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  coupon          Coupon   @relation(fields: [couponId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
  order           Order    @relation(fields: [orderId], references: [id])

  @@index([couponId])
  @@index([userId])
  @@map("coupon_usages")
}

model Promotion {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(200)
  description   String?  @db.Text
  type          String   @db.VarChar(30)
  rules         Json     @default("{}")
  startsAt      DateTime @map("starts_at")
  endsAt        DateTime @map("ends_at")
  isActive      Boolean  @default(true) @map("is_active")
  priority      Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("promotions")
}

// ============================================================================
// 11. REVIEW MODULE
// ============================================================================

model Review {
  id                  String       @id @default(uuid()) @db.Uuid
  productId           String       @map("product_id") @db.Uuid
  userId              String       @map("user_id") @db.Uuid
  orderId             String?      @map("order_id") @db.Uuid
  orderItemId         String?      @map("order_item_id") @db.Uuid
  rating              Int          @db.SmallInt
  title               String?      @db.VarChar(200)
  body                String?      @db.Text
  pros                String?      @db.Text
  cons                String?      @db.Text
  status              ReviewStatus @default(pending)
  isVerifiedPurchase  Boolean      @default(false) @map("is_verified_purchase")
  helpfulCount        Int          @default(0) @map("helpful_count")
  unhelpfulCount      Int          @default(0) @map("unhelpful_count")
  reportCount         Int          @default(0) @map("report_count")
  metadata            Json?        @default("{}")
  approvedAt          DateTime?    @map("approved_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  deletedAt           DateTime?    @map("deleted_at")

  // Relations
  product             Product      @relation(fields: [productId], references: [id])
  user                User         @relation(fields: [userId], references: [id])
  images              ReviewImage[]
  votes               ReviewVote[]
  reports             ReviewReport[]

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
  @@index([status])
  @@index([rating])
  @@map("reviews")
}

model ReviewImage {
  id          String   @id @default(uuid()) @db.Uuid
  reviewId    String   @map("review_id") @db.Uuid
  mediaId     String   @map("media_id") @db.Uuid
  altText     String?  @map("alt_text") @db.VarChar(255)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  review      Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_images")
}

model ReviewVote {
  id          String   @id @default(uuid()) @db.Uuid
  reviewId    String   @map("review_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  isHelpful   Boolean  @map("is_helpful")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  review      Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@map("review_votes")
}

model ReviewReport {
  id          String       @id @default(uuid()) @db.Uuid
  reviewId    String       @map("review_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  reason      ReportReason
  description String?      @db.Text
  status      String       @default("pending") @db.VarChar(20)
  reviewedBy  String?      @map("reviewed_by") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  reviewedAt  DateTime?    @map("reviewed_at")

  // Relations
  review      Review       @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_reports")
}

// ============================================================================
// 12. COMMENT MODULE
// ============================================================================

model Comment {
  id            String    @id @default(uuid()) @db.Uuid
  entityType    String    @map("entity_type") @db.VarChar(50)
  entityId      String    @map("entity_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  parentId      String?   @map("parent_id") @db.Uuid
  body          String    @db.Text
  isEdited      Boolean   @default(false) @map("is_edited")
  likeCount     Int       @default(0) @map("like_count")
  replyCount    Int       @default(0) @map("reply_count")
  status        String    @default("active") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  user          User      @relation(fields: [userId], references: [id])
  parent        Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[] @relation("CommentReplies")
  likes         CommentLike[]

  @@index([entityType, entityId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

model CommentLike {
  id          String   @id @default(uuid()) @db.Uuid
  commentId   String   @map("comment_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  comment     Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@map("comment_likes")
}

// ============================================================================
// 13. WISHLIST MODULE
